<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>TON PRO v23.0</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <style>
        body { background-color: #000; color: #fff; font-family: 'Inter', sans-serif; -webkit-tap-highlight-color: transparent; }
        .glass-card { background: #1c1c1e; border: 1px solid #333; border-radius: 24px; }
        .tab-content { display: none; transition: all 0.3s ease; }
        .active { display: block; animation: fadeIn 0.4s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .circle-btn { background: #007aff; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 15px rgba(0, 122, 255, 0.3); }
        .circle-btn:active { transform: scale(0.9); }
        input { background: #1c1c1e; border: 1px solid #444; border-radius: 16px; padding: 16px; width: 100%; color: white; outline: none; transition: 0.3s; }
        input:focus { border-color: #007aff; box-shadow: 0 0 0 1px #007aff; }
        .nav-btn { display: flex; flex-direction: column; align-items: center; gap: 4px; transition: 0.3s; }
        .nav-btn.active-nav { color: #007aff; }
    </style>
</head>
<body class="p-6 pb-32">

    <div id="home" class="tab-content active">
        <div class="flex justify-between items-center mt-4">
            <span class="bg-blue-600/20 text-blue-400 text-[10px] font-bold px-3 py-1 rounded-full border border-blue-500/20 uppercase tracking-tighter">Verified Wallet</span>
            <div id="user-badge" class="bg-white/5 px-3 py-1 rounded-full text-[10px] border border-white/10 font-bold uppercase">Major Fahim</div>
        </div>

        <div class="text-center my-12">
            <p class="text-gray-400 text-xs font-medium">Total Balance (TON)</p>
            <h1 id="main-balance" class="text-6xl font-black mt-2 tracking-tight">0.09</h1>
            <p class="text-green-400 text-sm mt-2 font-bold">≈ ৳14.50 BDT</p>
        </div>

        <div class="flex justify-center gap-16 mb-12">
            <button onclick="showTab('send')" class="flex flex-col items-center gap-3">
                <div class="circle-btn">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"></line><polyline points="5 12 12 5 19 12"></polyline></svg>
                </div>
                <span class="text-xs font-bold uppercase">Send</span>
            </button>
            <button onclick="showTab('deposit')" class="flex flex-col items-center gap-3">
                <div class="circle-btn">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                </div>
                <span class="text-xs font-bold uppercase">Deposit</span>
            </button>
        </div>

        <h2 class="text-xl font-bold mb-4 ml-1">My assets</h2>
        <div class="glass-card p-5 flex justify-between items-center mb-4">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-gradient-to-tr from-blue-700 to-blue-400 rounded-2xl flex items-center justify-center shadow-lg">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M12 2L4.5 20.29L5.21 21L12 18L18.79 21L19.5 20.29L12 2Z"/></svg>
                </div>
                <div>
                    <p class="font-black text-lg">TON</p>
                    <p class="text-[10px] text-gray-500">The Open Network</p>
                </div>
            </div>
            <div class="text-right">
                <p class="text-lg font-black">0.09</p>
                <p class="text-[10px] text-green-400">+5.24%</p>
            </div>
        </div>
    </div>

    <div id="send" class="tab-content">
        <h2 class="text-3xl font-black mb-8 mt-4">Send Assets</h2>
        <div class="space-y-6">
            <div>
                <label class="text-[10px] font-bold text-gray-500 uppercase ml-2 mb-2 block">Recipient Address</label>
                <input type="text" id="target" placeholder="Enter TON address...">
            </div>
            <div>
                <label class="text-[10px] font-bold text-gray-500 uppercase ml-2 mb-2 block">Amount to Send</label>
                <input type="number" id="amt" placeholder="0.00">
                <div class="flex justify-between mt-3 px-2">
                    <span class="text-[10px] text-blue-400 font-bold">Max: 0.09 TON</span>
                    <span class="text-[10px] text-gray-500 uppercase font-bold">Fee: 0.01 TON</span>
                </div>
            </div>
            <button onclick="processSend()" class="w-full bg-blue-600 py-5 rounded-2xl font-black text-lg shadow-xl shadow-blue-900/20 active:scale-95 transition-all mt-6">Confirm Transaction</button>
            <button onclick="showTab('home')" class="w-full py-4 text-gray-500 font-bold uppercase text-xs tracking-widest">Back to Wallet</button>
        </div>
    </div>

    <div id="deposit" class="tab-content">
        <h2 class="text-3xl font-black mb-8 mt-4 text-center">Deposit</h2>
        <div class="glass-card p-10 flex flex-col items-center">
            <div id="qrcode" class="bg-white p-3 rounded-3xl mb-8 shadow-2xl shadow-blue-500/10"></div>
            <p class="text-[10px] font-bold text-gray-500 uppercase mb-2">Your TON Address</p>
            <p id="wallet-addr" class="text-[11px] text-white/80 mb-6 text-center break-all font-mono leading-relaxed bg-white/5 p-3 rounded-xl border border-white/5">UQD7-YOUR-REAL-WALLET-ADDRESS</p>
            <button onclick="copyAddr()" class="bg-blue-600/10 text-blue-500 px-8 py-3 rounded-full font-black text-xs uppercase tracking-tighter border border-blue-500/20">Copy Address</button>
        </div>
        <p class="text-center text-[10px] text-gray-600 mt-6 px-10 leading-normal uppercase font-medium">Send only TON to this address. Sending other assets may result in permanent loss.</p>
        <button onclick="showTab('home')" class="w-full mt-12 text-gray-500 font-bold uppercase text-xs tracking-widest">Back</button>
    </div>

    <div id="history" class="tab-content">
        <h2 class="text-3xl font-black mb-8 mt-4">Transitions</h2>
        <div id="history-list" class="space-y-4">
            <div class="flex flex-col items-center justify-center py-20 opacity-30">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
                <p class="text-xs font-bold mt-4">Loading from MongoDB...</p>
            </div>
        </div>
        <button onclick="showTab('home')" class="w-full mt-12 text-gray-500 font-bold uppercase text-xs tracking-widest">Back</button>
    </div>

    <div class="fixed bottom-8 left-6 right-6 h-20 bg-[#1c1c1e]/80 backdrop-blur-2xl rounded-[32px] border border-white/5 flex justify-around items-center px-4 shadow-2xl shadow-black">
        <button onclick="showTab('home')" id="nav-home" class="nav-btn active-nav">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
            <span class="text-[9px] font-black uppercase tracking-tighter">Wallet</span>
        </button>
        <button onclick="showTab('history')" id="nav-history" class="nav-btn text-white/30">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"/></svg>
            <span class="text-[9px] font-black uppercase tracking-tighter">History</span>
        </button>
    </div>

    <script>
        const tele = window.Telegram.WebApp;
        tele.expand();
        tele.enableClosingConfirmation();
        
        // Configuration
        const MY_WALLET = "UQD7-YOUR-REAL-WALLET-ADDRESS"; // এখানে আপনার আসল অ্যাড্রেস দিন

        function showTab(id) {
            tele.HapticFeedback.impactOccurred('light');
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            
            // Nav Highlighting
            document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active-nav', 'text-white/30'));
            if(id === 'home') document.getElementById('nav-home').classList.add('active-nav');
            else if(id === 'history') document.getElementById('nav-history').classList.add('active-nav');
            else document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.add('text-white/30'));

            if(id === 'deposit') {
                document.getElementById('qrcode').innerHTML = "";
                new QRCode(document.getElementById("qrcode"), { 
                    text: MY_WALLET, 
                    width: 180, 
                    height: 180,
                    colorDark : "#000000",
                    colorLight : "#ffffff",
                    correctLevel : QRCode.CorrectLevel.H
                });
                document.getElementById('wallet-addr').innerText = MY_WALLET;
            }
        }

        function copyAddr() {
            navigator.clipboard.writeText(MY_WALLET);
            tele.HapticFeedback.notificationOccurred('success');
            tele.showAlert("Address Copied to Clipboard!");
        }

        function processSend() {
            const to = document.getElementById('target').value;
            const amount = document.getElementById('amt').value;
            
            if(!to || !amount || amount <= 0) {
                tele.HapticFeedback.notificationOccurred('error');
                return tele.showAlert("Please enter valid address and amount!");
            }
            
            tele.showConfirm(`Confirm sending ${amount} TON to:\n${to}`, (ok) => {
                if(ok) {
                    tele.HapticFeedback.impactOccurred('heavy');
                    // Sending data back to Bot
                    tele.sendData(JSON.stringify({
                        action: "send", 
                        to: to, 
                        amount: amount,
                        timestamp: new Date().getTime()
                    }));
                    tele.close();
                }
            });
        }
    </script>
</body>
</html>
